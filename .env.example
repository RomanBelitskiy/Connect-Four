# Скопіюй цей файл як .env і заповни значення:
# cp .env.example .env

# Токен Telegram-бота (отримай у @BotFather)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# URL Web App — МАЄ збігатися з Main Mini App у @BotFather (див. нижче)
WEBAPP_URL=https://quopnft.uk

# Username бота (опційно — підтягується з API при старті)
BOT_USERNAME=Connect4ClassicBot

# Menu Button — лише в BotFather (бот його не налаштовує).

# Порт сервера (за замовчуванням 3000)
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://connect_four_user:your_password@localhost:5432/connect_four
